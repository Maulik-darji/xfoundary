rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isMember() {
      return request.auth != null && exists(/databases/$(database)/documents/members/$(request.auth.uid));
    }

    // Allow users to read and write their own profile, and allow admins/members full access
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin() || isMember());
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin() || isMember());
      }
    }
    
    // Allow admins and members to read/write logs
    match /applicationLogs/{document=**} {
      allow read, write: if isAdmin() || isMember();
    }
    
    match /members/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin() || isMember());
    }

    match /admins/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /blog/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isMember();
    }

    match /memberApplications/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isMember() || request.auth.uid == document;
    }

    // Allow users to read/write their own login codes (though usually handled by admin functions)
    match /login_codes/{email} {
      allow read: if false; 
      allow write: if false;
    }
    
    // Allow the mail collection for the email trigger extension
    match /mail/{document=**} {
      allow create: if request.auth != null;
      allow read, write: if false;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
